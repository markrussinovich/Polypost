{
  "manifest_version": 3,
  "name": "LinkedIn Post Formatter",
  "version": "1.0.0",
  "description": "Draft LinkedIn posts with rich formatting, then publish through LinkedIn's own composer in one click.",
  "permissions": ["clipboardWrite", "scripting"],
  "host_permissions": ["https://www.linkedin.com/*", "https://*.linkedin.com/*"],
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_title": "Show LinkedIn Post Formatter",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/*", "https://*.linkedin.com/*"],
      "js": ["content-script.js"],
      "css": ["style.css"],
      "run_at": "document_idle",
      "all_frames": true,
      "match_origin_as_fallback": true
    }
  ]
}
